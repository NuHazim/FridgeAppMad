<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFE8E8"
    tools:context=".shoppingFragment">

    <!-- Add Item Button (Yellow Bar) -->
    <LinearLayout
        android:id="@+id/btnAddItemBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFD54F"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Item to the Shopping List"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Item Count Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF3E0"
        android:orientation="horizontal"
        android:padding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvItemCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 items to buy"
            android:textSize="13sp"
            android:textColor="#8D6E63" />

        <TextView
            android:id="@+id/tvCompletedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 completed"
            android:textSize="13sp"
            android:textColor="#8D6E63" />
    </LinearLayout>

    <!-- RecyclerView with proper weight -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFE8E8">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewShopping"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            tools:listitem="@layout/item_shopping" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No items in shopping list\nTap the button above to add items"
            android:textSize="16sp"
            android:textColor="#999999"
            android:textAlignment="center"
            android:gravity="center"
            android:visibility="gone"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>