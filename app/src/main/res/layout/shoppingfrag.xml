<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#e8e8e8"
    android:orientation="vertical"
    tools:context=".shopping.shoppingFragment">

    <!-- Add Item Button (Yellow Bar) -->
    <Button
        android:id="@+id/btnAddItemBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FD9700"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:text="+ Add Item to the Shopping List"
        android:layout_margin="20px">
    </Button>

    <!-- Item Count Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#e8e8e8"
        android:orientation="horizontal"
        android:padding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvItemCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 items to buy"
            android:textColor="#8D6E63"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCompletedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 completed"
            android:textColor="#8D6E63"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- RecyclerView with proper weight -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#e8e8e8">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewShopping"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="always"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_shopping" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="No items in shopping list\nTap the button above to add items"
            android:textAlignment="center"
            android:textColor="#999999"
            android:textSize="16sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Complete Purchase Button (shown at bottom when items are checked) -->
    <Button
        android:id="@+id/btnCompletePurchase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete Purchase"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:textAllCaps="false" />

</LinearLayout>